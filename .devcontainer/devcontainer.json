{
    "name": "Django Tutorial - Introdução",
    "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
    
    "features": {
        "ghcr.io/devcontainers/features/common-utils:1": {
            "configureZshAsDefaultShell": true
        }
    },

    // Configurações específicas do VS Code
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "batisteo.vscode-django",
                "mhutchie.git-graph"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.terminal.activateEnvInSelectedTerminal": true
            }
        }
    },

    // Expõe a porta 8000 (padrão do Django) para que o Codespaces crie o túnel HTTP
    "forwardPorts": [8000],

    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y sqlite3",

    "remoteUser": "vscode"
}
